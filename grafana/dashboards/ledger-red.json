{
  "uid": "ledger-red",
  "title": "Ledger — RED + Domain",
  "tags": ["ledger", "red"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (Rate)",
      "description": "HTTP requests/sec by endpoint, from Micrometer's http_server_requests.",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (Errors)",
      "description": "5xx responses/sec across all endpoints. Flat at zero until chaos is injected.",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) or vector(0)",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency (Duration)",
      "description": "Server-side p95 per endpoint via histogram_quantile over Micrometer buckets.",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, uri))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Postings throughput",
      "description": "Ledger postings/sec. Note: Micrometer's ledger.postings.created surfaces as ledger_postings_total (the client strips a trailing 'created', reserved by OpenMetrics).",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ledger_postings_total[1m])",
          "legendFormat": "postings/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Idempotency replays",
      "description": "How often a retried payment was deduplicated instead of double-posted — observability tied to correctness.",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ledger_idempotency_hits_total[1m]) or vector(0)",
          "legendFormat": "replays/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Posting latency p99",
      "description": "p99 of the domain-level posting timer (DB transaction included).",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(ledger_posting_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
